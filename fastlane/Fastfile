require "base64"

default_platform(:ios)

DEVELOPER_APP_ID = ENV["DEVELOPER_APP_ID"]
DEVELOPER_APP_IDENTIFIER = ENV["DEVELOPER_APP_IDENTIFIER"] || "com.nightvibes.appcode"
DEVELOPER_APP_EXTENSION_IDENTIFIER = ENV["DEVELOPER_APP_EXTENSION_IDENTIFIER"] || "com.nightvibes.appcode.extension"
DEVELOPER_PORTAL_TEAM_ID = ENV["DEVELOPER_PORTAL_TEAM_ID"]
TEMP_KEYCHAIN_USER = ENV["TEMP_KEYCHAIN_USER"] || "app-code-ci"
TEMP_KEYCHAIN_PASSWORD = ENV["TEMP_KEYCHAIN_PASSWORD"] || "app-code-ci-password"
APPLE_ISSUER_ID = ENV["APPLE_ISSUER_ID"]
APPLE_KEY_ID = ENV["APPLE_KEY_ID"]
APPLE_KEY_CONTENT = ENV["APPLE_KEY_CONTENT"]
GIT_AUTHORIZATION = ENV["GIT_AUTHORIZATION"]
MATCH_READONLY = ENV.fetch("MATCH_READONLY", "true") == "true"
MATCH_FORCE = ENV.fetch("MATCH_FORCE", "false") == "true"
MATCH_SKIP_CERTIFICATE_MATCHING = ENV.fetch("MATCH_SKIP_CERTIFICATE_MATCHING", "true") == "true"
DISTRIBUTE_EXTERNAL = ENV["DISTRIBUTE_EXTERNAL"] == "true"
XCODE_PATH = ENV["XCODE_PATH"] || "/Applications/Xcode_26.5.app"
WAIT_FOR_TESTFLIGHT_PROCESSING = ENV.fetch("WAIT_FOR_TESTFLIGHT_PROCESSING", "false") == "true"
TESTFLIGHT_PROCESSING_TIMEOUT = ENV.fetch("TESTFLIGHT_PROCESSING_TIMEOUT", "2400").to_i
TESTFLIGHT_CHANGELOG = ENV["TESTFLIGHT_CHANGELOG"] || "Improved the command center, editor tabs, Source Control dashboard, GitHub clone flow, search results, remote setup, notifications, settings, and iOS 26 Liquid Glass polish."

# App Code is local-only; keep upstream Judge0 remote execution disabled.
JUDGE0_KEY = ""
JUDGE0_ENDPOINT = ""

def delete_temp_keychain(name)
  delete_keychain(name: name) if File.exist? File.expand_path("~/Library/Keychains/#{name}-db")
end

def create_temp_keychain(name, password)
  create_keychain(name: name, password: password, unlock: false, timeout: 0)
end

def ensure_temp_keychain(name, password)
  delete_temp_keychain(name)
  create_temp_keychain(name, password)
end

def ensure_resources
  Dir.chdir("..") do
    sh("./scripts/bootstrap_resources.sh")
    sh(%Q[printf 'let JUDGE0_ENDPOINT = ""
let JUDGE0_KEY = ""
' > CodeApp/Constants/Secrets.swift])
  end
end

def resolve_and_patch_packages
  Dir.chdir("..") do
    sh(%Q[xcodebuild -resolvePackageDependencies -project Code.xcodeproj -scheme "Code App" -derivedDataPath build/DerivedData])
    sh("./scripts/patch_swift_packages.sh build/DerivedData")
  end
end

platform :ios do
  lane :beta do
    xcode_select(XCODE_PATH)
    ensure_resources
    resolve_and_patch_packages

    keychain_name = TEMP_KEYCHAIN_USER
    keychain_password = TEMP_KEYCHAIN_PASSWORD
    ensure_temp_keychain(keychain_name, keychain_password)

    api_key = app_store_connect_api_key(
      key_id: APPLE_KEY_ID,
      issuer_id: APPLE_ISSUER_ID,
      key_content: APPLE_KEY_CONTENT,
      duration: 1100,
      in_house: false
    )

    latest_build = latest_testflight_build_number(
      app_identifier: DEVELOPER_APP_IDENTIFIER,
      api_key: api_key
    )
    requested_build = ENV.fetch("TESTFLIGHT_BUILD_NUMBER", "").strip
    next_build = requested_build.empty? ? latest_build + 1 : requested_build.to_i
    UI.user_error!("TESTFLIGHT_BUILD_NUMBER must be greater than #{latest_build}") if next_build <= latest_build

    increment_build_number(
      xcodeproj: "Code.xcodeproj",
      build_number: next_build
    )

    match(
      type: "appstore",
      app_identifier: [DEVELOPER_APP_IDENTIFIER, DEVELOPER_APP_EXTENSION_IDENTIFIER],
      team_id: DEVELOPER_PORTAL_TEAM_ID,
      git_basic_authorization: Base64.strict_encode64(GIT_AUTHORIZATION),
      readonly: MATCH_READONLY,
      force: MATCH_FORCE,
      skip_certificate_matching: MATCH_SKIP_CERTIFICATE_MATCHING,
      keychain_name: keychain_name,
      keychain_password: keychain_password,
      api_key: api_key
    )

    Dir.chdir("..") do
      sh("./scripts/prepare_third_party_sdks.sh")
    end

    gym(
      configuration: "Release",
      project: "Code.xcodeproj",
      scheme: "Code App",
      export_method: "app-store",
      output_name: "AppCode",
      derived_data_path: "build/DerivedData",
      skip_package_dependencies_resolution: true,
      xcargs: "DEVELOPMENT_TEAM=#{DEVELOPER_PORTAL_TEAM_ID}"
    )

    pilot_options = {
      apple_id: DEVELOPER_APP_ID,
      app_identifier: DEVELOPER_APP_IDENTIFIER,
      ipa: "./AppCode.ipa",
      skip_submission: true,
      skip_waiting_for_build_processing: !WAIT_FOR_TESTFLIGHT_PROCESSING,
      api_key: api_key
    }

    if WAIT_FOR_TESTFLIGHT_PROCESSING
      pilot_options[:wait_processing_timeout_duration] = TESTFLIGHT_PROCESSING_TIMEOUT
      pilot_options[:changelog] = TESTFLIGHT_CHANGELOG
    end

    pilot(pilot_options)

    delete_temp_keychain(keychain_name)
  end

  lane :tests do
    xcode_select(XCODE_PATH)
    ensure_resources
    resolve_and_patch_packages
    run_tests(scheme: "Code UI")
  end
end
